void gfx_draw_shell_input(const char *input) {
    uint32_t bg = rgb(1, 4, 13);
    uint32_t cursor = rgb(90, 170, 255);
    uint32_t text = rgb(210, 230, 255);

    uint32_t base_x = 50;
    uint32_t line1_y = gfx_height - 58;
    uint32_t line2_y = gfx_height - 30;
    uint32_t cursor_x = base_x;

    int len = 0;
    int max_chars;
    int start_idx = 0;
    int split_idx = 0;
    int second_len = 0;

    char line1[96];
    char line2[96];

    if (!gfx_ready) {
        return;
    }

    /*
     * Clear input zone only, not LOS answer above it.
     */
    gfx_fill_rect(0, line1_y - 10, gfx_width, 72, bg);

    if (!input || !input[0]) {
        gfx_fill_rect(base_x, line2_y + 2, 10, 24, cursor);
        return;
    }

    while (input[len]) {
        len++;
    }

    /*
     * 5x7 font scaled by 2: roughly 12 px per char.
     */
    max_chars = (int)((gfx_width - 100) / 12);
    if (max_chars > 90) {
        max_chars = 90;
    }
    if (max_chars < 16) {
        max_chars = 16;
    }

    /*
     * Show only last 2 visual lines.
     */
    if (len > max_chars * 2) {
        start_idx = len - max_chars * 2;
    }

    split_idx = len - start_idx;
    if (split_idx > max_chars) {
        split_idx = max_chars;
    }

    for (int i = 0; i < split_idx && i < 95; i++) {
        line1[i] = input[start_idx + i];
    }
    line1[split_idx] = '\0';

    second_len = len - start_idx - split_idx;
    if (second_len > max_chars) {
        second_len = max_chars;
    }

    for (int i = 0; i < second_len && i < 95; i++) {
        line2[i] = input[start_idx + split_idx + i];
    }
    line2[second_len] = '\0';

    if (line1[0]) {
        gfx_draw_text(base_x, line1_y, line1, text, 2);
    }

    if (line2[0]) {
        gfx_draw_text(base_x, line2_y, line2, text, 2);
    }

    cursor_x = base_x + (uint32_t)(second_len * 12);
    if (!line2[0]) {
        cursor_x = base_x + (uint32_t)(split_idx * 12);
        gfx_fill_rect(cursor_x, line1_y + 2, 10, 24, cursor);
        return;
    }

    if (cursor_x > gfx_width - 24) {
        cursor_x = gfx_width - 24;
    }

    gfx_fill_rect(cursor_x, line2_y + 2, 10, 24, cursor);
}









