static void gfx_draw_ai_background(void) {
    uint32_t bg = rgb(1, 4, 13);
    uint32_t grid = rgb(7, 18, 38);
    uint32_t dot = rgb(18, 48, 88);

    uint32_t x;
    uint32_t y;

    if (!gfx_ready) {
        return;
    }

    gfx_clear(bg);

    /*
     * Very subtle fullscreen grid.
     */
    for (y = 64; y < gfx_height; y += 64) {
        gfx_draw_hline(0, y, gfx_width, grid);
    }

    for (x = 64; x < gfx_width; x += 64) {
        gfx_draw_vline(x, 0, gfx_height, grid);
    }

    /*
     * Deterministic tiny particles.
     * No random generator needed.
     */
    for (y = 32; y < gfx_height - 80; y += 37) {
        for (x = 28; x < gfx_width - 28; x += 53) {
            uint32_t v = (x * 17u + y * 31u + gfx_anim_tick / 9000u) % 97u;

            if (v < 7u) {
                gfx_put_pixel(x, y, dot);
                if (x + 1 < gfx_width) {
                    gfx_put_pixel(x + 1, y, dot);
                }
            }
        }
    }
}

static void gfx_buf_draw_segment_ring_circle(
    int cx,
    int cy,
    int r_outer,
    int thickness,
    uint32_t color,
    int phase,
    int period,
    int keep
) {
    if (r_outer <= 0 || thickness <= 0 || period <= 0 || keep <= 0) {
        return;
    }

    int r_inner = r_outer - thickness;
    if (r_inner < 0) {
        r_inner = 0;
    }

    int outer2 = r_outer * r_outer;
    int inner2 = r_inner * r_inner;

    for (int y = -r_outer; y <= r_outer; y++) {
        for (int x = -r_outer; x <= r_outer; x++) {
            int d2 = x * x + y * y;

            if (d2 <= outer2 && d2 >= inner2) {
                int marker = (x * 3 + y * 5 + phase) % period;

                if (marker < 0) {
                    marker += period;
                }

                if (marker < keep) {
                    gfx_buf_put_pixel(cx + x, cy + y, color);
                }
            }
        }
    }
}


static void gfx_draw_model_ring(void) {
    uint32_t bg = rgb(1, 4, 13);
    uint32_t blue = rgb(90, 170, 255);
    uint32_t pale = rgb(180, 220, 255);
    uint32_t dim = rgb(24, 58, 105);
    uint32_t deep = rgb(8, 24, 52);

    int screen_cx;
    int screen_cy;

    int cx = MODEL_RING_BOX / 2;
    int cy = MODEL_RING_BOX / 2;

    int pulse = 0;
    int phase = 0;
    int radius = 108;

    if (!gfx_ready) {
        return;
    }

    /*
     * Animated renderer is used for the main AI surface only.
     * Workspace uses a separate static top-right ring.
     */
    screen_cx = (int)(gfx_width / 2);
    screen_cy = (int)(gfx_height / 2) - 28;

    gfx_buf_clear(bg);

    phase = (int)(gfx_anim_tick / 9000);

    if (gfx_get_model_state() == 0) {
        /*
         * idle: calm living core, no aggressive pulse
         */
        pulse = (int)((gfx_anim_tick / 60000) % 10);
        if (pulse > 5) {
            pulse = 10 - pulse;
        }

        gfx_buf_draw_ring_circle(cx, cy, radius + pulse, 3, dim);
        gfx_buf_draw_segment_ring_circle(cx, cy, radius - 18, 4, blue, phase, 34, 15);
        gfx_buf_draw_ring_circle(cx, cy, radius - 48, 2, deep);
        return gfx_blit_model_ring_buffer(screen_cx, screen_cy);
    }

    if (gfx_get_model_state() == 1) {
        /*
         * loading: breathing outer shell
         */
        pulse = (int)((gfx_anim_tick / 18000) % 24);
        if (pulse > 12) {
            pulse = 24 - pulse;
        }

        gfx_buf_draw_ring_circle(cx, cy, radius + pulse, 4, blue);
        gfx_buf_draw_segment_ring_circle(cx, cy, radius - 22, 4, pale, phase * 2, 28, 12);
        gfx_buf_draw_ring_circle(cx, cy, radius - 52, 2, dim);
        return gfx_blit_model_ring_buffer(screen_cx, screen_cy);
    }

    if (gfx_get_model_state() == 2) {
        /*
         * ready: stable bright ring
         */
        pulse = (int)((gfx_anim_tick / 70000) % 8);
        if (pulse > 4) {
