static void gfx_copy_text_255(char *dst, const char *src) {
    int i = 0;

    if (!dst) {
        return;
    }

    if (!src) {
        dst[0] = '\0';
        return;
    }

    while (src[i] && i < 255) {
        dst[i] = src[i];
        i++;
    }

    dst[i] = '\0';
}


static void gfx_draw_text_wrapped(
    uint32_t x,
    uint32_t y,
    const char *text,
    uint32_t color,
    uint32_t scale,
    uint32_t max_width,
    int max_lines
) {
    char line[128];
    int line_len = 0;
    int lines = 0;
    int last_space = -1;
    int max_chars;

    if (!text || !text[0] || max_lines <= 0) {
        return;
    }

    /*
     * gfx_draw_text uses roughly 6 pixels per glyph at scale 1.
     */
    max_chars = (int)(max_width / (6 * scale));
    if (max_chars < 8) {
        max_chars = 8;
    }

    for (int i = 0; ; i++) {
        char c = text[i];

        if (c == '\n' || c == '\0') {
            line[line_len] = '\0';
            gfx_draw_text(x, y + (uint32_t)(lines * 18 * scale), line, color, scale);
            lines++;
            line_len = 0;
            last_space = -1;

            if (c == '\0' || lines >= max_lines) {
                return;
            }

            continue;
        }

        if (line_len < 126) {
            if (c == ' ') {
                last_space = line_len;
            }

            line[line_len++] = c;
        }

        if (line_len >= max_chars) {
            int cut = line_len;

            if (last_space > 6) {
                cut = last_space;
            }

            line[cut] = '\0';
            gfx_draw_text(x, y + (uint32_t)(lines * 18 * scale), line, color, scale);
            lines++;

            if (lines >= max_lines) {
                return;
            }

            if (cut < line_len) {
                int out = 0;
                int j = cut;

                while (j < line_len && line[j] == ' ') {
                    j++;
                }

                while (j < line_len && out < 126) {
                    line[out++] = line[j++];
                }

                line_len = out;
            } else {
                line_len = 0;
            }

            last_space = -1;
            for (int k = 0; k < line_len; k++) {
                if (line[k] == ' ') {
                    last_space = k;
                }
            }
        }
    }
}


static void gfx_render_host_note(void) {
    uint32_t bg = rgb(1, 4, 13);
    uint32_t fg = rgb(210, 230, 255);
    uint32_t accent = rgb(90, 170, 255);
    uint32_t dim = rgb(35, 55, 95);

    uint32_t x = 50;
    uint32_t y = gfx_height - 146;
    uint32_t w = gfx_width - 100;

    const char *status = "READY";

    if (!gfx_ready) {
        return;
    }

    if (gfx_get_model_state() == 0) {
        status = "IDLE";
    } else if (gfx_get_model_state() == 1) {
        status = "LOADING...";
    } else if (gfx_get_model_state() == 2) {
        status = "READY";
    } else if (gfx_get_model_state() == 3) {
        status = "THINKING...";
    } else if (gfx_get_model_state() == 4) {
        status = "DRAWING UI...";
    }

    /*
     * Persistent bottom conversation area.
     */
    gfx_fill_rect(0, y - 24, gfx_width, 104, bg);
    gfx_draw_hline(x, y - 12, w, dim);

    gfx_draw_text(x, y, "LOS", accent, 1);
    gfx_draw_text(x + 42, y, status, accent, 1);

    if (gfx_host_note_text[0]) {
        gfx_draw_text(x, y + 28, "LOS:", accent, 1);
        gfx_draw_text_wrapped(x + 46, y + 28, gfx_host_note_text, fg, 1, w - 46, 3);
    }
}







void gfx_set_current_input(const char *input) {
    int i = 0;

    if (!input) {
        gfx_current_input[0] = '\0';
        return;
    }

    while (input[i] && i < 255) {
        gfx_current_input[i] = input[i];
        i++;
    }

    gfx_current_input[i] = '\0';
}


