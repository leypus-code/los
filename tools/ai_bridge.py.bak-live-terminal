#!/usr/bin/env python3
import os
import socket
import sys
import time

from providers.factory import create_provider

SOCK = "/tmp/los-ai.sock"

DEFAULT_PROVIDER = os.environ.get("LOS_AI_PROVIDER", "ollama")
DEFAULT_MODEL = os.environ.get("LOS_AI_MODEL", "qwen2.5:0.5b")

# Retained bridge-side UI state.
current_surface = "ai"
current_layout = "empty"
current_widgets = []



def connect_loop():
    while True:
        try:
            s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            s.connect(SOCK)
            return s
        except FileNotFoundError:
            print("[bridge] waiting for /tmp/los-ai.sock ...")
            time.sleep(0.5)
        except ConnectionRefusedError:
            print("[bridge] socket exists but QEMU is not ready yet ...")
            time.sleep(0.5)


def send_ui(sock, kind, payload):
    global current_surface, current_layout, current_widgets

    payload = str(payload or "")
    payload = payload.replace("\n", " ").replace("\r", " ")

    if kind == "surface":
        if payload in ("ai", "workspace"):
            current_surface = payload

    if kind == "workspace" and payload == "reset":
        current_widgets = []
        current_layout = "empty"

    if kind == "layout":
        if payload in ("coding", "debug", "empty"):
            current_layout = payload

    if kind == "widget":
        append_unique(current_widgets, payload)

    line = f"LOS_UI|{kind}|{payload}\n"
    sock.sendall(line.encode("utf-8"))
    print(f"[host -> los] {line.strip()}")

def prompt_words(prompt):
    return str(prompt or "").lower().replace("!", " ").replace("?", " ").replace(".", " ").replace(",", " ").split()


def is_vague_screen_request(prompt):
    low = str(prompt or "").lower().strip()

    has_screen = "screen" in low or "surface" in low or "interface" in low
    has_specific = (
        "coding" in low
        or "code" in low
        or "debug" in low
        or "terminal" in low
        or "editor" in low
        or "files" in low
        or "file" in low
        or "logs" in low
        or "docker" in low
        or "ssh" in low
        or "browser" in low
        or "workspace" in low
    )

    # "make me a screen" must ask clarification, not create random widgets.
    return has_screen and not has_specific


def is_explicit_workspace_request(prompt):
    low = str(prompt or "").lower()

    action = (
        "create" in low
        or "make" in low
        or "build" in low
        or "open" in low
        or "generate" in low
        or "add" in low
        or "show" in low
        or "prepare" in low
        or "set up" in low
        or "setup" in low
    )

    concrete_target = (
        "workspace" in low
        or "coding" in low
        or "code" in low
        or "debug" in low
        or "terminal" in low
        or "editor" in low
        or "files" in low
        or "file" in low
        or "logs" in low
        or "docker" in low
        or "ssh" in low
        or "browser" in low
        or "widget" in low
    )

    if is_vague_screen_request(prompt):
        return False

    return action and concrete_target

def append_unique(items, value):
    if value and value not in items:
        items.append(value)


def infer_layout_from_prompt(prompt):
    low = str(prompt or "").lower()

    if "debug" in low or "logs" in low or "docker" in low:
        return "debug"

    if (
        "code" in low
        or "coding" in low
        or "editor" in low
        or "terminal" in low
        or "shell" in low
        or "workspace" in low
    ):
        return "coding"

    return "empty"


def infer_widgets_from_prompt(prompt):
    low = str(prompt or "").lower()
    widgets = []

    if "editor" in low or "edit" in low or "code" in low or "coding" in low:
        append_unique(widgets, "editor")

    if "terminal" in low or "shell" in low or "command" in low or "commands" in low:
        append_unique(widgets, "terminal")

    if "files" in low or "file" in low or "project tree" in low or "tree" in low:
        append_unique(widgets, "files")

    if "logs" in low or "log" in low:
        append_unique(widgets, "logs")

    if "docker" in low or "container" in low or "containers" in low or "service" in low or "services" in low:
        append_unique(widgets, "docker")

    if "ssh" in low or "remote" in low:
        append_unique(widgets, "ssh")

    if "browser" in low or "web" in low or "docs" in low or "preview" in low:
        append_unique(widgets, "browser")

    return widgets



def apply_model_plan(sock, prompt, answer):
    clarification_requested = False
    layout_values = []
    widget_values = []
    note_value = None
    chat_value = None

    raw_answer = str(answer or "").strip()
    raw_lower = raw_answer.lower()
    low_prompt = str(prompt or "").lower()

    explicit_workspace = is_explicit_workspace_request(prompt)
    vague_screen = is_vague_screen_request(prompt)

    # Vague screen request: ask clarification, but DO NOT switch surface.
    # If user is in workspace, answer appears in workspace bottom chat area.
    if vague_screen and not explicit_workspace:
        send_ui(sock, "note", "What kind of LOS screen do you need: coding, debug, files, or terminal?")
        send_ui(sock, "state", "ready")
        return

    # Refusal from small model: convert to useful LOS reply.
    if "can't help" in raw_lower or "cannot help" in raw_lower or "i'm sorry" in raw_lower:
        if explicit_workspace:
            raw_answer = ""
        else:
            send_ui(sock, "note", "Tell me what LOS interface you want: coding, debug, files, terminal, or services.")
            send_ui(sock, "state", "ready")
            return

    lines = []
    for raw in raw_answer.splitlines():
        line = raw.strip()
        if line:
            lines.append(line)

    saw_protocol = False

    for line in lines:
        upper = line.upper()

        if upper.startswith("CHAT "):
            saw_protocol = True
            chat_value = line[5:].strip()
            continue

        if upper.startswith("ASK "):
            saw_protocol = True
            chat_value = line[4:].strip()
            clarification_requested = True
            continue

        if upper.startswith("STATE "):
            saw_protocol = True
            continue

        if upper.startswith("SURFACE "):
            saw_protocol = True
            continue

        if upper.startswith("LAYOUT "):
            saw_protocol = True
            value = line[7:].strip().lower()
            if value == "debugging":
                value = "debug"
            append_unique(layout_values, value)
            continue

        if upper.startswith("WIDGET "):
            saw_protocol = True
            value = line[7:].strip().lower()
            append_unique(widget_values, value)
            continue

        if upper.startswith("NOTE "):
            saw_protocol = True
            note_value = line[5:].strip()
            continue

    # Normal chat reply without protocol: show it on current surface.
    # DO NOT send SURFACE ai here.
    if not saw_protocol and not explicit_workspace:
        send_ui(sock, "state", "ready")
        send_ui(sock, "note", raw_answer[:120] if raw_answer else "Ready.")
        return

    # If model asks clarification and user did not explicitly request UI, show question on current surface.
    if clarification_requested and not explicit_workspace:
        send_ui(sock, "state", "ready")
        send_ui(sock, "note", chat_value or "Clarification needed.")
        return

    # Non-UI conversation: stay wherever user currently is.
    if not explicit_workspace:
        send_ui(sock, "state", "ready")
        send_ui(sock, "note", chat_value or note_value or "Ready.")
        return

    # Explicit UI request:
    # merge model plan with deterministic widgets inferred from user's prompt.
    # User intent wins over weak model output like LAYOUT empty.
    inferred_layout = infer_layout_from_prompt(prompt)

    if not layout_values:
        append_unique(layout_values, inferred_layout)
    elif inferred_layout != "empty" and "empty" in layout_values:
        layout_values = [v for v in layout_values if v != "empty"]
        append_unique(layout_values, inferred_layout)

    for widget in infer_widgets_from_prompt(prompt):
        append_unique(widget_values, widget)

    # Sensible defaults.
    if not widget_values and layout_values and layout_values[0] == "coding":
        append_unique(widget_values, "editor")
        append_unique(widget_values, "terminal")

    if not widget_values and layout_values and layout_values[0] == "debug":
        append_unique(widget_values, "logs")
        append_unique(widget_values, "terminal")

    if chat_value and not chat_value.endswith("?"):
        send_ui(sock, "note", chat_value[:120])
        time.sleep(0.10)
    else:
        send_ui(sock, "note", "Understood, building the requested LOS interface.")
        time.sleep(0.10)

    send_ui(sock, "state", "drawing")
    send_ui(sock, "note", "Building interface...")
    time.sleep(0.10)

    send_ui(sock, "workspace", "reset")
    send_ui(sock, "surface", "workspace")

    for layout in layout_values:
        send_ui(sock, "layout", layout)

    for widget in widget_values:
        send_ui(sock, "widget", widget)

    if note_value and not note_value.endswith("?"):
        send_ui(sock, "note", note_value[:120])
    elif chat_value and not chat_value.endswith("?"):
        send_ui(sock, "note", chat_value[:120])
    else:
        send_ui(sock, "note", "Workspace prepared.")

    send_ui(sock, "state", "ready")

def looks_like_workspace_request(prompt, answer):
    low = (prompt + " " + answer).lower()

    return (
        "workspace" in low
        or "space" in low
        or "coding" in low
        or "terminal" in low
        or "editor" in low
        or "рабоч" in low
        or "терминал" in low
        or "редактор" in low
        or "код" in low
    )



def normalize_widget_word(text):
    low = str(text or "").lower()

    if "terminal" in low or "shell" in low or "console" in low:
        return "terminal"

    if "editor" in low or "edit" in low or "code" in low:
        return "editor"

    if "files" in low or "file" in low or "filesystem" in low or "overview" in low or "tree" in low:
        return "files"

    if "logs" in low or "log" in low or "logf" in low:
        return "logs"

    if "docker" in low or "container" in low or "containers" in low:
        return "docker"

    if "ssh" in low or "remote" in low:
        return "ssh"

    if "browser" in low or "web" in low or "preview" in low:
        return "browser"

    return None


def mentioned_widgets(prompt):
    low = str(prompt or "").lower()
    found = []

    candidates = [
        ("editor", ["editor", "edit", "code"]),
        ("terminal", ["terminal", "shell", "console"]),
        ("files", ["files", "file", "filesystem", "overview", "tree"]),
        ("logs", ["logs", "log", "logf"]),
        ("docker", ["docker", "container", "containers"]),
        ("ssh", ["ssh", "remote"]),
        ("browser", ["browser", "web", "preview"]),
    ]

    positions = []

    for widget, words in candidates:
        best = -1

        for word in words:
            pos = low.find(word)

            if pos != -1 and (best == -1 or pos < best):
                best = pos

        if best != -1:
            positions.append((best, widget))

    positions.sort(key=lambda x: x[0])

    for _, widget in positions:
        append_unique(found, widget)

    return found


def render_current_workspace(sock, note):
    send_ui(sock, "state", "drawing")
    send_ui(sock, "note", "Updating workspace...")
    time.sleep(0.10)

    send_ui(sock, "workspace", "reset")
    send_ui(sock, "surface", "workspace")
    send_ui(sock, "layout", current_layout)

    for widget in current_widgets:
        send_ui(sock, "widget", widget)

    send_ui(sock, "state", "ready")
    send_ui(sock, "note", note)


def local_workspace_update(sock, prompt):
    global current_layout, current_widgets, current_surface

    low = str(prompt or "").lower().strip()

    if current_surface != "workspace":
        return False

    widgets = mentioned_widgets(prompt)

    wants_update = (
        "change" in low
        or "replace" in low
        or "instead" in low
        or "swap" in low
        or "remove" in low
        or "delete" in low
        or "add" in low
        or "put" in low
        or "use" in low
    )

    if not wants_update:
        return False

    if not widgets:
        return False

    new_widgets = list(current_widgets)

    def remove_widget(widget):
        while widget in new_widgets:
            new_widgets.remove(widget)

    def add_widget(widget):
        append_unique(new_widgets, widget)

    # "instead of X ... Y" => replace X with Y
    if "instead of" in low and len(widgets) >= 2:
        src = widgets[0]
        dst = widgets[-1]
        remove_widget(src)
        add_widget(dst)

    # "X change to Y", "change X to Y", "replace X with Y"
    elif ("change" in low or "replace" in low or "swap" in low) and len(widgets) >= 2:
        src = widgets[0]
        dst = widgets[-1]
        remove_widget(src)
        add_widget(dst)

    # "remove X"
    elif "remove" in low or "delete" in low:
        for widget in widgets:
            remove_widget(widget)

    # "add X", "put X", "use X"
    elif "add" in low or "put" in low or "use" in low:
        for widget in widgets:
            add_widget(widget)

    else:
        return False

    if not new_widgets:
        if current_layout == "debug":
            new_widgets = ["logs", "terminal"]
        else:
            new_widgets = ["editor", "terminal"]

    current_widgets = new_widgets

    render_current_workspace(sock, "Workspace updated.")
    return True



def builtin_answer(prompt):
    from datetime import datetime

    low = str(prompt or "").lower().strip()
    now = datetime.now()

    if "what can you do" in low or "what do you do" in low or "help" == low or low.startswith("help "):
        return (
            "I can talk with you, create LOS workspaces, add editor, terminal, files, "
            "logs, docker, ssh or browser widgets, and answer simple local questions."
        )

    asks_time = "time" in low or "what time" in low
    asks_date = "date" in low or "today" in low or "day" in low
    asks_year = "year" in low or "what year" in low

    if asks_time and not ("runtime" in low or "timer" in low):
        return "Current host time is " + now.strftime("%H:%M") + "."

    if asks_year:
        return "The current year is " + now.strftime("%Y") + "."

    if asks_date or asks_time:
        return "Today is " + now.strftime("%Y-%m-%d") + "."

    return None

def ai_response(sock, provider, prompt):
    print(f"[ai] provider={provider.name} model={provider.model}")
    print(f"[ai] prompt: {prompt}")

    send_ui(sock, "state", "thinking")
    send_ui(sock, "note", "Thinking...")
    time.sleep(0.15)

    if local_workspace_update(sock, prompt):
        return

    builtin = builtin_answer(prompt)
    if builtin:
        send_ui(sock, "state", "ready")
        send_ui(sock, "note", builtin)
        return

    try:
        answer = provider.ask(prompt)
        if not answer:
            raise RuntimeError("empty provider answer")

        print(f"[{provider.name}] {answer}")

    except Exception as e:
        print(f"[{provider.name}] error: {e}")
        print("[provider] falling back to fake response")

        fallback = create_provider("fake", provider.model)
        answer = fallback.ask(prompt)

    apply_model_plan(sock, prompt, answer)


def main():
    provider_name = DEFAULT_PROVIDER
    model_name = DEFAULT_MODEL

    provider = create_provider(provider_name, model_name)

    print("[bridge] LOS AI bridge v24.8")
    print("[bridge] provider abstraction enabled")
    print("[bridge] start LOS with: make run-ai-bridge")
    print(f"[bridge] provider: {provider.name}")
    print(f"[bridge] model: {provider.model}")

    sock = connect_loop()
    print("[bridge] connected")

    buffer = b""

    while True:
        chunk = sock.recv(1024)

        if not chunk:
            print("[bridge] disconnected")
            break

        buffer += chunk

        while b"\n" in buffer:
            raw, buffer = buffer.split(b"\n", 1)
            text = raw.decode("utf-8", errors="replace").strip()

            if not text:
                continue

            print(f"[los -> host] {text}")

            if not text.startswith("LOS_AI|"):
                continue

            parts = text.split("|", 2)
            kind = parts[1] if len(parts) > 1 else "unknown"
            payload = parts[2] if len(parts) > 2 else ""

            if kind == "mode":
                print(f"[ai] provider mode = {payload}")

                if payload == "offline":
                    send_ui(sock, "state", "idle")
                else:
                    send_ui(sock, "state", "ready")
                    send_ui(sock, "note", f"Host AI ready. Provider: {provider.name}. Model: {provider.model}")

            elif kind == "load":
                requested = payload.strip()

                if requested:
                    model_name = requested

                print(f"[ai] load model requested: {model_name}")

                send_ui(sock, "state", "loading")
                send_ui(sock, "note", f"Loading model: {model_name}")

                try:
                    message = provider.load_model(model_name)
                except Exception as e:
                    print(f"[provider] load error: {e}")
                    provider = create_provider("fake", model_name)
                    message = provider.load_model(model_name)

                time.sleep(0.35)

                send_ui(sock, "state", "ready")
                send_ui(sock, "note", message)

            elif kind == "ask":
                ai_response(sock, provider, payload)

            else:
                print(f"[ai] unknown packet kind={kind} payload={payload}")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print()
        print("[bridge] stopped")
        sys.exit(0)
